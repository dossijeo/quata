<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="ToolbarTheme">
        <item name="android:textColorPrimary">@color/white</item>
        <item name="android:textColorSecondary">@color/white</item>
        <item name="android:textColor">@color/title_info_color</item>
        <item name="actionMenuTextColor">@color/white</item>
        <item name="colorControlNormal">@color/white</item>
    </style>

    <style name="ButtonText" parent="@style/Widget.AppCompat.Button.Borderless">
        <item name="android:textSize">@dimen/text_size_button_text</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:gravity">center</item>
        <item name="android:paddingTop">@dimen/button_vertical_padding</item>
        <item name="android:paddingBottom">@dimen/button_vertical_padding</item>
        <item name="android:textAllCaps">false</item>
        <item name="textStyle">@integer/regular</item>
    </style>

    <style name="NewAppTheme" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryDark">@color/purple_700</item>
        <item name="colorAccent">@color/navigation_text_color_selected</item>
        <item name="android:fontFamily">sans</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowContentTransitions">true</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:statusBarColor">@color/bg</item>
        <item name="android:navigationBarColor">@color/bg</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="android:textColorPrimary">@color/title_info_color</item>
        <item name="android:textColorSecondary">@color/subject_child_color</item>
        <item name="android:textColorHighlight">@color/navigation_text_color_selected</item>
        <item name="android:textColorHint">@color/subject_child_color</item>
        <item name="android:colorFocusedHighlight">@color/navigation_text_color_selected</item>
        <item name="android:colorControlNormal">@color/title_info_color</item>
        <item name="android:colorControlActivated">@color/navigation_text_color_selected</item>
        <item name="android:colorControlHighlight">@color/list_item_pressed</item>
        <item name="android:windowSharedElementEnterTransition">@transition/shared_element_enter_exit</item>
        <item name="android:windowSharedElementExitTransition">@transition/shared_element_enter_exit</item>
    </style>

    <style name="PrimaryText">
        <item name="android:textSize">@dimen/text_size_primary_text</item>
        <item name="android:textColor">@color/title_info_color</item>
        <item name="android:lineSpacingExtra">4sp</item>
        <item name="textStyle">@integer/regular</item>
    </style>

    <style name="SecondaryText">
        <item name="android:textSize">@dimen/_8sdp</item>
        <item name="android:textColor">@color/subject_child_color</item>
        <item name="android:lineSpacingExtra">3sp</item>
        <item name="textStyle">@integer/light</item>
    </style>

    <style name="ToolbarSubtitle">
        <item name="android:textSize">@dimen/text_size_toolbar_subtitle</item>
        <item name="android:textColor">@color/subject_child_color</item>
        <item name="textStyle">@integer/light</item>
    </style>

    <style name="ToolbarTitle">
        <item name="android:textSize">@dimen/text_size_toolbar_title</item>
        <item name="android:textColor">@color/title_info_color</item>
        <item name="android:lineSpacingExtra">3sp</item>
        <item name="textStyle">@integer/semi_bold</item>
    </style>

    <style name="PageTitleBold">
        <item name="android:textSize">@dimen/text_size_page_title_bold</item>
        <item name="android:textColor">@color/title_info_color</item>
        <item name="textStyle">@integer/extra_bold</item>
    </style>
</resources>
